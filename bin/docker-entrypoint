#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails runner "Rails.application.load_seed if TicketType.none?"

  if [ -n "$PURGE_ORDER_DATA" ]; then
    ./bin/rails runner "[Refund, Invoice, Ticket, PaymentEvent, Order].each(&:delete_all); Coupon.update_all(uses_count: 0); Rails.logger.info('PURGE_ORDER_DATA: cleared all order, payment, and invoice data')"
  fi
fi

exec "${@}"
