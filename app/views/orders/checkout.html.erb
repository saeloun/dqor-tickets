<% content_for :head do %>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<% end %>

<main class="page-shell narrow">
  <header class="page-hero">
    <p class="eyebrow">Order <%= @order.code %></p>
    <h1>Review your order</h1>
  </header>

  <section class="form-card order-summary">
    <% @order.tickets.includes(:ticket_type).group_by(&:ticket_type).each do |ticket_type, tickets| %>
      <p><span><%= tickets.size %> × <%= ticket_type.name %></span><strong><%= number_to_currency(tickets.sum(&:price_paise) / 100.0, unit: "₹") %></strong></p>
    <% end %>
    <% if @order.metadata.fetch("discount_paise", 0).positive? %>
      <p><span>Coupon discount</span><strong>-<%= number_to_currency(@order.metadata.fetch("discount_paise") / 100.0, unit: "₹") %></strong></p>
    <% end %>
    <p class="order-total"><span>Total</span><strong><%= number_to_currency(@order.total_paise / 100.0, unit: "₹") %></strong></p>
  </section>

  <% if @order.paid? %>
    <section class="status-card status-card--paid">
      <h2>Confirmed</h2>
      <p>Your complimentary order is ready.</p>
      <%= link_to "View tickets", order_path(@order.code), class: "btn-primary" %>
    </section>
  <% else %>
    <section
      class="status-card"
      data-controller="checkout"
      data-checkout-key-value="<%= ENV['RAZORPAY_KEY_ID'] %>"
      data-checkout-order-id-value="<%= @order.razorpay_order_id %>"
      data-checkout-name-value="<%= @order.buyer_name %>"
      data-checkout-email-value="<%= @order.email %>"
      data-checkout-amount-value="<%= @order.total_paise %>"
      data-checkout-expires-at-value="<%= @order.expires_at.iso8601 %>"
      data-checkout-callback-url-value="<%= payment_callback_path %>"
      data-checkout-csrf-value="<%= form_authenticity_token %>">
      <p>Complete payment within <strong data-checkout-target="countdown">30:00</strong>.</p>
      <button type="button" class="btn-primary" data-checkout-target="button" data-action="checkout#open">Pay securely with Razorpay</button>
    </section>
  <% end %>
</main>
