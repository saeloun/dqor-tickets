<% content_for :title, "Order #{@order.code} · Deccan Queen on Rails" %>

<main class="status-page">
  <%= turbo_frame_tag "order_status", data: { controller: "poll", poll_url_value: order_path(@order.code), poll_active_value: @order.pending? } do %>
    <section class="status-card status-card--<%= @order.status %>">
      <p class="section-label">Order <%= @order.code %></p>

      <% if @order.pending? %>
        <div class="spinner" aria-hidden="true"></div>
        <h1>Confirming your payment</h1>
        <% if @order.payment_events.exists?(kind: "payment.failed") %>
          <p>The payment failed. No charge was confirmed. You can return and try again.</p>
          <%= link_to "Choose tickets", root_path, class: "btn btn-primary" %>
        <% else %>
          <p>Razorpay is confirming the payment. This page updates automatically.</p>
          <p class="status-hint" role="status">Please keep this page open.</p>
        <% end %>
      <% elsif @order.paid? %>
        <% tickets = @order.tickets.where(canceled_at: nil).includes(:ticket_type).to_a %>
        <% assigned_count = tickets.count(&:assigned?) %>
        <span class="success-icon" aria-hidden="true">✓</span>
        <h1>Your tickets are confirmed</h1>
        <p>We sent the invoice to <strong><%= @order.email %></strong>.</p>

        <% if flash[:notice] %>
          <p class="notice" role="status"><%= flash[:notice] %></p>
        <% end %>
        <% if flash[:alert] %>
          <p class="alert" role="alert"><%= flash[:alert] %></p>
        <% end %>

        <div class="download-list">
          <% if (invoice = @order.invoices.invoice.first)&.pdf&.attached? %>
            <%= link_to "Download tax invoice", rails_blob_path(invoice.pdf, disposition: "attachment"), class: "btn btn-gold" %>
          <% end %>
          <% @order.invoices.credit_note.each do |credit_note| %>
            <%= link_to "Download credit note #{credit_note.number}", rails_blob_path(credit_note.pdf, disposition: "attachment"), class: "btn btn-gold" if credit_note.pdf.attached? %>
          <% end %>
        </div>

        <div class="attendee-summary">
          <h2><%= assigned_count %> of <%= tickets.size %> tickets assigned</h2>
          <% if assigned_count < tickets.size %>
            <p>Assign each ticket now, or share its private claim link with the attendee.</p>
          <% end %>

          <% tickets.each do |ticket| %>
            <article class="ticket-assignment">
              <h3><%= ticket.ticket_type.name %></h3>
              <% if ticket.assigned? %>
                <p><strong><%= ticket.attendee_name %></strong><br><%= ticket.attendee_email %></p>
                <p class="assignment-summary">
                  <%= ticket.tshirt_size.presence || "No T-shirt size" %>
                  <span aria-hidden="true">·</span>
                  <%= ticket.dietary_preference.presence || "No dietary notes" %>
                  <% if ticket.childcare_needed? %><span aria-hidden="true">·</span> Needs childcare<% end %>
                </p>
                <%= link_to "Download ticket", rails_blob_path(ticket.pdf, disposition: "attachment"), class: "btn btn-gold" if ticket.pdf.attached? %>
              <% end %>

              <%= render "ticket_assignments/form", ticket:, url: assign_order_ticket_path(@order.code, ticket) %>
              <div class="claim-link field" data-controller="clipboard">
                <%= label_tag "claim_link_#{ticket.id}", ticket.assigned? ? "Private link for the attendee to update their details" : "Private claim link" %>
                <div class="claim-link__row">
                  <%= text_field_tag "claim_link_#{ticket.id}", ticket_claim_url(ticket.claim_token), readonly: true, data: { clipboard_target: "source" } %>
                  <button type="button" class="claim-link__copy" data-action="clipboard#copy" data-clipboard-target="button">Copy</button>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% elsif @order.expired? %>
        <h1>This order expired</h1>
        <p>The inventory hold ended before payment confirmation. No payment was captured.</p>
        <%= link_to "Try again", root_path, class: "btn btn-secondary" %>
      <% else %>
        <h1>This order was canceled</h1>
        <%= link_to "Return to tickets", root_path, class: "btn btn-secondary" %>
      <% end %>
    </section>
  <% end %>
</main>
