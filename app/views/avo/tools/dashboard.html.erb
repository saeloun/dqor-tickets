<div class="space-y-6">
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-gray-500">Gross revenue</p>
      <p class="text-3xl font-semibold"><%= number_to_currency(@gross_revenue / 100.0, unit: "₹", format: "%u%n") %></p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-gray-500">Net after refunds</p>
      <p class="text-3xl font-semibold"><%= number_to_currency(@net_revenue / 100.0, unit: "₹", format: "%u%n") %></p>
    </div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Sold by ticket type</h2>
    <div class="space-y-3">
      <% @sold_by_type.each do |ticket_type, sold| %>
        <div class="flex justify-between gap-4">
          <span><%= ticket_type.name %></span>
          <strong><%= sold %> / <%= ticket_type.capacity || "∞" %></strong>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Orders in the last 7 days</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-7">
      <% 6.downto(0) do |days_ago| %>
        <% date = days_ago.days.ago.to_date %>
        <div>
          <p class="text-sm text-gray-500"><%= date.strftime("%a, %d %b") %></p>
          <p class="text-2xl font-semibold"><%= @orders_last_seven_days.fetch(date.iso8601, 0) %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
