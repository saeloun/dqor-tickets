<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 18px;border:1px solid #e0d2b2;border-radius:6px;">
  <tr>
    <td style="background:#7a1220;border-radius:5px 5px 0 0;padding:12px 16px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td align="left" style="font-family:<%= MailerHelper::BODY_FONT %>;color:#ffffff;font-size:16px;font-weight:600;"><%= ticket.ticket_type.name %></td>
          <td align="right" style="font-family:<%= MailerHelper::BODY_FONT %>;color:#ffffff;font-size:15px;letter-spacing:0.06em;">DQOR-<%= ticket.id %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:16px 16px 4px;">
      <%= mail_field "Attendee", ticket.attendee_name %>
      <%= mail_field "Email", ticket.attendee_email %>
      <%= mail_field "T-shirt size", ticket.tshirt_size %>
      <%= mail_field "Dietary restrictions", ticket.dietary_preference %>
      <%= mail_field "Childcare", ticket.childcare_needed? ? "Needed" : "Not needed" %>
    </td>
  </tr>
</table>
