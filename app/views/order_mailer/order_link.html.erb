<% tickets = @order.tickets.reject(&:canceled_at?) %>
<% unassigned = tickets.reject(&:assigned?) %>
<%= mail_heading "Your order #{@order.code}" %>
<%= mail_text "Hello #{@order.buyer_name}," %>
<%= mail_text "Here is the permanent link to your order. Bookmark it — it is where you download your tickets and tax invoice, and where you name your attendees." %>

<p style="margin:0 0 20px;"><%= mail_button "Open my order", order_url(@order.code) %></p>

<% if unassigned.any? %>
  <%= mail_text "#{pluralize(unassigned.size, "ticket")} still #{unassigned.one? ? "has" : "have"} nobody named on #{unassigned.one? ? "it" : "them"}." %>
<% else %>
  <%= mail_text "All #{pluralize(tickets.size, "ticket")} already have an attendee. If anything needs correcting, use the links below." %>
<% end %>

<%= mail_divider %>

<%= mail_label "One link per ticket" %>
<%= mail_note "Send an attendee their own link and they fill in their own name, dietary needs, T-shirt size and childcare." %>

<%= render "order_mailer/claim_links", order: @order %>

<%= mail_text "See you in Pune." %>
