<%= mail_heading "Your tickets are confirmed" %>
<%= mail_text "Hello #{@order.buyer_name}," %>

<% if @documents_pending %>
  <%= mail_text do %>Payment for order <strong><%= @order.code %></strong> is confirmed. Your tax invoice is being prepared and will be available from your order page.<% end %>
<% else %>
  <%= mail_text do %>Payment for order <strong><%= @order.code %></strong> is confirmed. Your tax invoice is attached.<% end %>
<% end %>

<% unassigned = @order.tickets.reject(&:canceled_at?).reject(&:assigned?) %>
<% if unassigned.any? %>
  <%= mail_text "You've got #{pluralize(@order.tickets.count, "ticket")}, and #{unassigned.size == @order.tickets.count ? "nobody is named on them yet" : "#{pluralize(unassigned.size, "ticket")} still #{unassigned.one? ? "has" : "have"} nobody named on #{unassigned.one? ? "it" : "them"}"}. That is fine — assign them whenever you are ready." %>
<% else %>
  <%= mail_text "You've got #{pluralize(@order.tickets.count, "ticket")}, and every one already has an attendee named on it." %>
<% end %>

<p style="margin:0 0 20px;"><%= mail_button "Assign your tickets", order_url(@order.code) %></p>

<%= mail_divider %>

<%= mail_label "Send an attendee their own link" %>
<%= mail_note "They fill in their own name, dietary needs, T-shirt size and childcare, and their ticket is emailed straight to them." %>

<%= render "order_mailer/claim_links", order: @order %>

<%= mail_note "Keep this email — these links are how you and your attendees manage the tickets." %>
<%= mail_text "See you in Pune." %>
