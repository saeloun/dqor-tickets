<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 16px;">
  <% order.tickets.reject(&:canceled_at?).each do |ticket| %>
    <tr>
      <td style="padding:7px 0;border-bottom:1px solid #e4d6b6;font-family:<%= MailerHelper::BODY_FONT %>;color:#33302c;font-size:15px;line-height:1.5;">
        <%= ticket.ticket_type.name %>
        <% if ticket.assigned? %>
          — <%= ticket.attendee_name %>
          (<%= mail_link "Change details", ticket_claim_url(ticket.claim_token) %>)
        <% else %>
          — <%= mail_link "Claim this ticket", ticket_claim_url(ticket.claim_token) %>
        <% end %>
      </td>
    </tr>
  <% end %>
</table>
